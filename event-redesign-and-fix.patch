@@ -0,0 +1,250 @@
+"use client";
+
+import { useEffect, useMemo, useState } from "react";
+import Link from "next/link";
+import { getEventTheme, type GoalType, type GoalConfig } from "@/lib/weekend-events";
+
+interface WeekendEvent {
+  id: string;
+  title: string;
+  description: string;
+  goal_type: GoalType;
+  goal_config: GoalConfig;
+  starts_at: string;
+  ends_at: string;
+  status: "upcoming" | "active" | "closed";
+}
+
+interface LeaderboardRow {
+  student_id: string;
+  display_name: string;
+  avatar_url: string | null;
+  progress: number;
+  rank: number | null;
+  is_me: boolean;
+}
+
+function goalLabel(ev: WeekendEvent) {
+  const c = ev.goal_config ?? {};
+  switch (ev.goal_type) {
+    case "books_count":
+      return `Finish ${c.target ?? "?"} book${(c.target ?? 0) === 1 ? "" : "s"}`;
+    case "genre_diversity":
+      return `Finish books from ${c.target ?? "?"} different genres`;
+    case "author_prefix":
+      return `Finish books by an author starting with "${c.prefix ?? "?"}"`;
+    case "topic":
+      return `Finish ${c.target ?? "?"} book${(c.target ?? 0) === 1 ? "" : "s"} about ${c.topic ?? "a topic"}`;
+    default:
+      return "";
+  }
+}
+
+function useCountdown(targetIso: string) {
+  const [msLeft, setMsLeft] = useState(() => new Date(targetIso).getTime() - Date.now());
+
+  useEffect(() => {
+    const interval = setInterval(() => {
+      setMsLeft(new Date(targetIso).getTime() - Date.now());
+    }, 1000);
+    return () => clearInterval(interval);
+  }, [targetIso]);
+
+  const clamped = Math.max(0, msLeft);
+  const days = Math.floor(clamped / (1000 * 60 * 60 * 24));
+  const hours = Math.floor((clamped / (1000 * 60 * 60)) % 24);
+  const minutes = Math.floor((clamped / (1000 * 60)) % 60);
+  const seconds = Math.floor((clamped / 1000) % 60);
+
+  return { days, hours, minutes, seconds, isOver: msLeft <= 0 };
+}
+
+function CountdownBlock({ label, value }: { label: string; value: number }) {
+  return (
+    <div className="flex flex-col items-center rounded-2xl bg-white/15 px-3 py-2 backdrop-blur-sm min-w-[64px]">
+      <span className="font-kids-display text-2xl font-bold text-white tabular-nums">
+        {String(value).padStart(2, "0")}
+      </span>
+      <span className="text-[10px] font-semibold uppercase tracking-wide text-white/80">{label}</span>
+    </div>
+  );
+}
+
+export function EventDetailClient({
+  event,
+  leaderboard,
+  hasJoined: initialHasJoined,
+  myProgress,
+}: {
+  event: WeekendEvent;
+  leaderboard: LeaderboardRow[];
+  hasJoined: boolean;
+  myProgress: number;
+}) {
+  const [hasJoined, setHasJoined] = useState(initialHasJoined);
+  const [joining, setJoining] = useState(false);
+  const [joinError, setJoinError] = useState("");
+
+  const theme = getEventTheme(event.goal_type, event.title, event.description);
+  const target = Number(event.goal_config?.target ?? 1);
+  const pct = Math.min(100, Math.round((myProgress / target) * 100));
+
+  const countdownTarget = event.status === "upcoming" ? event.starts_at : event.ends_at;
+  const countdown = useCountdown(countdownTarget);
+
+  const countdownLabel = useMemo(() => {
+    if (event.status === "closed") return "Event ended";
+    if (countdown.isOver) return event.status === "upcoming" ? "Starting now!" : "Wrapping up…";
+    return event.status === "upcoming" ? "Starts in" : "Ends in";
+  }, [event.status, countdown.isOver]);
+
+  const winners = leaderboard.filter((r) => r.rank !== null && r.rank <= 3);
+
+  async function handleJoin() {
+    setJoining(true);
+    setJoinError("");
+    const res = await fetch(`/api/events/${event.id}/join`, { method: "POST" });
+    if (!res.ok) {
+      const data = await res.json().catch(() => ({}));
+      setJoinError(data.error ?? "Couldn't join right now — try again.");
+    } else {
+      setHasJoined(true);
+    }
+    setJoining(false);
+  }
+
+  return (
+    <div>
+      <Link href="/kids/events" className="text-sm font-semibold text-kids-purple">
+        ← Back to events
+      </Link>
+
+      <div className={`mt-3 overflow-hidden rounded-3xl bg-gradient-to-br ${theme.gradient} p-6 text-white shadow-lg sm:p-8`}>
+        <div className="flex items-start justify-between gap-4">
+          <div>
+            <span className="text-5xl">{theme.emoji}</span>
+            <h1 className="mt-3 font-kids-display text-2xl font-bold sm:text-3xl">{event.title}</h1>
+            <p className="mt-2 max-w-xl text-sm text-white/90 sm:text-base">{event.description}</p>
+            <p className="mt-3 inline-block rounded-full bg-white/20 px-3 py-1 text-xs font-bold uppercase tracking-wide">
+              {goalLabel(event)}
+            </p>
+          </div>
+          <span
+            className={`shrink-0 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide ${
+              event.status === "active"
+                ? "bg-emerald-400/90 text-emerald-950"
+                : event.status === "upcoming"
+                ? "bg-amber-300/90 text-amber-950"
+                : "bg-white/20 text-white"
+            }`}
+          >
+            {event.status}
+          </span>
+        </div>
+
+        {event.status !== "closed" && (
+          <div className="mt-6">
+            <p className="text-xs font-semibold uppercase tracking-wide text-white/70">{countdownLabel}</p>
+            <div className="mt-2 flex gap-2">
+              <CountdownBlock label="Days" value={countdown.days} />
+              <CountdownBlock label="Hrs" value={countdown.hours} />
+              <CountdownBlock label="Min" value={countdown.minutes} />
+              <CountdownBlock label="Sec" value={countdown.seconds} />
+            </div>
+          </div>
+        )}
+
+        <div className="mt-6">
+          {hasJoined ? (
+            <div className="rounded-2xl bg-white/15 p-4">
+              <p className="font-kids-display text-lg font-bold">🎉 You're in!</p>
+              <div className="mt-2 h-3 overflow-hidden rounded-full bg-white/25">
+                <div
+                  className="h-full rounded-full bg-white transition-all duration-500"
+                  style={{ width: `${pct}%` }}
+                />
+              </div>
+              <p className="mt-1 text-sm text-white/90">
+                {myProgress} / {target} — {pct >= 100 ? "Goal complete! 🏆" : "keep going!"}
+              </p>
+            </div>
+          ) : event.status === "closed" ? (
+            <p className="text-sm text-white/80">This event has ended.</p>
+          ) : (
+            <div>
+              <button
+                type="button"
+                onClick={handleJoin}
+                disabled={joining}
+                className="rounded-2xl bg-white px-6 py-3 font-kids-display text-base font-bold text-slate-900 shadow-md transition hover:scale-[1.02] disabled:opacity-60"
+              >
+                {joining ? "Joining…" : "🙋 Join this challenge!"}
+              </button>
+              {joinError && <p className="mt-2 text-sm text-amber-200">{joinError}</p>}
+            </div>
+          )}
+        </div>
+      </div>
+
+      {winners.length > 0 && (
+        <section className="mt-8">
+          <h2 className="font-kids-display text-xl font-bold">Winners 🎉</h2>
+          <div className="mt-3 grid gap-3 sm:grid-cols-3">
+            {winners.map((w) => (
+              <div
+                key={w.student_id}
+                className={`rounded-2xl bg-white p-4 text-center shadow-md ${w.is_me ? "ring-2 ring-kids-yellow" : ""}`}
+              >
+                <p className="text-3xl">{w.rank === 1 ? "🥇" : w.rank === 2 ? "🥈" : "🥉"}</p>
+                <p className="mt-1 font-bold text-slate-900">{w.display_name}</p>
+                <p className="text-xs text-slate-500">
+                  {w.progress} / {target}
+                </p>
+              </div>
+            ))}
+          </div>
+        </section>
+      )}
+
+      <section className="mt-8">
+        <h2 className="font-kids-display text-xl font-bold">Leaderboard</h2>
+        <div className="mt-3 overflow-hidden rounded-2xl bg-white shadow-sm">
+          <table className="w-full text-left text-sm">
+            <thead className="bg-violet-50 text-slate-600">
+              <tr>
+                <th className="px-4 py-3">Rank</th>
+                <th className="px-4 py-3">Reader</th>
+                <th className="px-4 py-3">Progress</th>
+              </tr>
+            </thead>
+            <tbody>
+              {leaderboard.length === 0 ? (
+                <tr>
+                  <td colSpan={3} className="px-4 py-8 text-center text-slate-500">
+                    {hasJoined ? "No one has made progress yet — be the first!" : "Join to be the first on the board!"}
+                  </td>
+                </tr>
+              ) : (
+                leaderboard.map((r) => (
+                  <tr
+                    key={r.student_id}
+                    className={`border-t border-violet-50 ${r.is_me ? "bg-violet-50/60 font-semibold" : ""}`}
+                  >
+                    <td className="px-4 py-3">{r.rank ?? "—"}</td>
+                    <td className="px-4 py-3">
+                      {r.display_name}
+                      {r.is_me ? " (you)" : ""}
+                    </td>
+                    <td className="px-4 py-3">
+                      {r.progress} / {target}
+                    </td>
+                  </tr>
+                ))
+              )}
+            </tbody>
+          </table>
+        </div>
+      </section>
+    </div>
+  );
+}
